# Copiar a .env y completar valores

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_DATABASE=sistema_chalito
DB_PORT=3306

JWT_SECRET=
PORT=3001

# Cola automática RECIBIDO → EN_PREPARACION (worker, carta web, post-pago).
# false = todos los pedidos quedan en RECIBIDOS hasta mover manualmente desde admin.
AUTO_MOVER_PEDIDOS=true

# Carta online + Mercado Pago (HTTPS público en producción)
FRONTEND_URL=https://panel.example.com
CARTA_FRONTEND_URL=https://example.com
# Orígenes extra para CORS/Socket.IO (csv)
ALLOWED_ORIGINS=https://www.elchalito.com,https://www.gestionelchalito.com
BACKEND_URL=https://api.example.com
MP_ACCESS_TOKEN=
# Secreto del webhook (panel MP → Tu integración → Webhooks)
MP_WEBHOOK_SECRET=

# Imágenes de artículos (servidor propio)
FILES_BASE_URL=https://files.elchalito.com
FILES_UPLOAD_PATH=/opt/files
