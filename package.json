{
  "name": "sistema-chalito-backend",
  "version": "1.0.0",
  "description": "Backend API para Sistema Gastronómico Chalito",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "test": "node --test --test-concurrency=1 --test-force-exit tests/*.test.js tests/config/*.test.js tests/middlewares/authorizeModule.test.js tests/services/couponService.test.js tests/services/storeScheduleService.test.js tests/services/whatsappMessageBuilder.test.js tests/services/mercadoPagoPaymentStateMachine.test.js tests/services/mercadoPagoPaymentLogger.test.js tests/services/whatsappClienteAlLocal.test.js tests/services/whatsappSettingsService.test.js tests/services/whatsappTemplateValidator.test.js tests/services/PersonalizacionesService.test.js tests/services/socketServiceExport.test.js",
    "test:jest": "jest --testPathPattern='tests/(services/OrderQueueEngine|services/TimeCalculationService|services/montoConCuantoAbonaRules|services/pedidoOperativoHelper|controllers/articulosController|controllers/pedidosHorarioEntrega|middlewares/rateLimitMiddleware)\\.test\\.js$'",
    "test:ci": "npm test",
    "migrate": "node scripts/runMigrations.js",
    "migrate:baseline": "node scripts/markMigrationsApplied.js 001_empleados_base.sql 002_stock_semanal_inventario.sql 003_articulos_controla_stock.sql 004_clientes.sql 005_checkout_sesiones_mp.sql 005_usuarios_avatar_ultima_conexion.sql 006_rename_articulo_contenido_a_articulos_contenido.sql 006_configuracion_general_base.sql",
    "seed": "node scripts/seed.js",
    "reset:operational": "node scripts/resetOperationalData.js",
    "reset:operational:confirm": "node scripts/resetOperationalData.js --confirm"
  },
  "keywords": [
    "api",
    "restaurant",
    "pos",
    "gastronomico",
    "nodejs",
    "mysql"
  ],
  "author": "Tu Nombre",
  "license": "ISC",
  "dependencies": {
    "@arcasdk/core": "^0.3.6",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}